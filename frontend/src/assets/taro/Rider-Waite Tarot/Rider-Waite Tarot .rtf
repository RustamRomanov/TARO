\cb3 \uc0\u1040 \u1088 \u1090 \u1091 \u1088  \u1069 \u1076 \u1074 \u1072 \u1088 \u1076  \u1059 \u1101 \u1081 \u1090  (1857-1942) \'97 \u1086 \u1076 \u1080 \u1085  \u1080 \u1079  \u1082 \u1088 \u1091 \u1087 \u1085 \u1077 \u1081 \u1096 \u1080 \u1093  \u1079 \u1085 \u1072 \u1090 \u1086 \u1082 \u1086 \u1074  \u1101 \u1079 \u1086 \u1090 \u1077 \u1088 \u1080 \u1095 \u1077 \u1089 \u1082 \u1080 \u1093  \u1085 \u1072 \u1091 \u1082  \u1089 \u1074 \u1086 \u1077 \u1075 \u1086  \u1074 \u1088 \u1077 \u1084 \u1077 \u1085 \u1080 , \u1091 \u1095 \u1077 \u1085 \u1080 \u1082  \u1080  \u1087 \u1086 \u1089 \u1083 \u1077 \u1076 \u1086 \u1074 \u1072 \u1090 \u1077 \u1083 \u1100  \u1079 \u1085 \u1072 \u1084 \u1077 \u1085 \u1080 \u1090 \u1086 \u1075 \u1086  \u1069 \u1090 \u1090 \u1077 \u1081 \u1083 \u1099 . \u1054 \u1076 \u1085 \u1086  \u1074 \u1088 \u1077 \u1084 \u1103  \u1059 \u1101 \u1081 \u1090  \u1088 \u1091 \u1082 \u1086 \u1074 \u1086 \u1076 \u1080 \u1083  \u1086 \u1082 \u1082 \u1091 \u1083 \u1100 \u1090 \u1085 \u1099 \u1084  \u1054 \u1088 \u1076 \u1077 \u1085 \u1086 \u1084  \'ab\u1047 \u1086 \u1083 \u1086 \u1090 \u1086 \u1081  \u1047 \u1072 \u1088 \u1080 \'bb. \u1042  1908 \u1075 \u1086 \u1076 \u1091  \u1059 \u1101 \u1081 \u1090  \u1085 \u1072 \u1087 \u1080 \u1089 \u1072 \u1083  \u1082 \u1085 \u1080 \u1075 \u1091  \'ab\u1048 \u1083 \u1083 \u1102 \u1089 \u1090 \u1088 \u1080 \u1088 \u1086 \u1074 \u1072 \u1085 \u1085 \u1099 \u1081  \u1050 \u1083 \u1102 \u1095  \u1082  \u1058 \u1072 \u1088 \u1086 \'bb. \u1042  \u1074 \u1074 \u1077 \u1076 \u1077 \u1085 \u1080 \u1080  \u1082  \u1082 \u1085 \u1080 \u1075 \u1077  \u1077 \u1089 \u1090 \u1100  \u1090 \u1072 \u1082 \u1080 \u1077  \u1089 \u1083 \u1086 \u1074 \u1072 : \'ab\u1055 \u1086 \u1076 \u1083 \u1080 \u1085 \u1085 \u1086 \u1077  \u1058 \u1072 \u1088 \u1086  \'97 \u1101 \u1090 \u1086  \u1089 \u1080 \u1084 \u1074 \u1086 \u1083 \u1080 \u1079 \u1084 ; \u1085 \u1080 \u1082 \u1072 \u1082 \u1086 \u1081  \u1076 \u1088 \u1091 \u1075 \u1086 \u1081  \u1103 \u1079 \u1099 \u1082  \u1080  \u1076 \u1088 \u1091 \u1075 \u1080 \u1077  \u1079 \u1085 \u1072 \u1082 \u1080  \u1077 \u1084 \u1091  \u1085 \u1077  \u1074 \u1077 \u1076 \u1086 \u1084 \u1099 . \u1045 \u1075 \u1086  \u1101 \u1084 \u1073 \u1083 \u1077 \u1084 \u1099 , \u1089  \u1090 \u1086 \u1095 \u1082 \u1080  \u1079 \u1088 \u1077 \u1085 \u1080 \u1103  \u1080 \u1093  \u1087 \u1086 \u1090 \u1072 \u1077 \u1085 \u1085 \u1086 \u1075 \u1086  \u1079 \u1085 \u1072 \u1095 \u1077 \u1085 \u1080 \u1103 , \u1089 \u1082 \u1083 \u1072 \u1076 \u1099 \u1074 \u1072 \u1102 \u1090 \u1089 \u1103  \u1074  \u1089 \u1074 \u1086 \u1077 \u1086 \u1073 \u1088 \u1072 \u1079 \u1085 \u1099 \u1081  \u1072 \u1083 \u1092 \u1072 \u1074 \u1080 \u1090 , \u1086 \u1073 \u1088 \u1072 \u1079 \u1091 \u1103  \u1085 \u1077 \u1089 \u1084 \u1077 \u1090 \u1085 \u1086 \u1077  \u1095 \u1080 \u1089 \u1083 \u1086  \u1089 \u1086 \u1095 \u1077 \u1090 \u1072 \u1085 \u1080 \u1081  \u1080  \u1087 \u1088 \u1080 \u1076 \u1072 \u1074 \u1072 \u1103  \u1074 \u1089 \u1077 \u1084 \u1091  \u1080 \u1089 \u1090 \u1080 \u1085 \u1085 \u1099 \u1081  \u1089 \u1084 \u1099 \u1089 \u1083 . \u1053 \u1072  \u1074 \u1099 \u1089 \u1086 \u1095 \u1072 \u1081 \u1096 \u1077 \u1084  \u1091 \u1088 \u1086 \u1074 \u1085 \u1077  \u1086 \u1085 \u1086  \u1076 \u1072 \u1077 \u1090  \u1085 \u1072 \u1084  \u1082 \u1083 \u1102 \u1095  \u1082  \u1090 \u1072 \u1080 \u1085 \u1089 \u1090 \u1074 \u1072 \u1084 \'85\'bb. \u1057 \u1086 \u1074 \u1084 \u1077 \u1089 \u1090 \u1085 \u1086  \u1089  \u1093 \u1091 \u1076 \u1086 \u1078 \u1085 \u1080 \u1094 \u1077 \u1081  \u1055 \u1072 \u1084 \u1077 \u1083 \u1086 \u1081  \u1050 \u1086 \u1083 \u1084 \u1077 \u1085 -\u1057 \u1084 \u1080 \u1090  \u1059 \u1101 \u1081 \u1090  \u1080 \u1079 \u1075 \u1086 \u1090 \u1086 \u1074 \u1080 \u1083  \u1085 \u1086 \u1074 \u1091 \u1102  \u1082 \u1086 \u1083 \u1086 \u1076 \u1091  \u1082 \u1072 \u1088 \u1090  \u1058 \u1072 \u1088 \u1086 . \u1041 \u1091 \u1076 \u1091 \u1095 \u1080  \u1095 \u108