\f0\b \cb3 \uc0\u1040 \u1085 \u1085 \u1086 \u1090 \u1072 \u1094 \u1080 \u1103 
\f1\b0 :\'a0Trionfi della Luna (\uc0\u1074 \u1072 \u1088 \u1080 \u1072 \u1094 \u1080 \u1103  \u1085 \u1072 \u1079 \u1074 \u1072 \u1085 \u1080 \u1103  \'97 333 Tarot) \'97 \u1089 \u1088 \u1077 \u1076 \u1085 \u1077 \u1074 \u1077 \u1082 \u1086 \u1074 \u1086 -\u1084 \u1072 \u1088 \u1089 \u1077 \u1083 \u1100 \u1089 \u1082 \u1072 \u1103  \u1082 \u1091 \u1079 \u1080 \u1085 \u1072 \'a0Deviant Moon Tarot. \u1057 \u1090 \u1080 \u1083 \u1100  \u1101 \u1090 \u1080 \u1093  \u1072 \u1085 \u1090 \u1080 \u1082 \u1074 \u1072 \u1088 \u1085 \u1099 \u1093  \u1082 \u1072 \u1088 \u1090  \u1086 \u1095 \u1077 \u1085 \u1100  \u1085 \u1077 \u1087 \u1088 \u1080 \u1085 \u1091 \u1078 \u1076 \u1077 \u1085 \u1085 \u1099 \u1081  \u1080  \u1086 \u1088 \u1075 \u1072 \u1085 \u1080 \u1095 \u1085 \u1099 \u1081 . \u1050 \u1086 \u1083 \u1086 \u1076 \u1072 \'a0\u1074 \u1099 \u1087 \u1091 \u1089 \u1082 \u1072 \u1077 \u1090 \u1089 \u1103  \u1086 \u1075 \u1088 \u1072 \u1085 \u1080 \u1095 \u1077 \u1085 \u1085 \u1099 \u1084  \u1090 \u1080 \u1088 \u1072 \u1078 \u1086 \u1084 , \u1089 \u1086 \u1089 \u1090 \u1086 \u1080 \u1090  \'a0\u1080 \u1079  \u1087 \u1086 \u1083 \u1085 \u1099 \u1093  \u1057 \u1090 \u1072 \u1088 \u1096 \u1080 \u1093  \u1080  \u1052 \u1083 \u1072 \u1076 \u1096 \u1080 \u1093  \u1072 \u1088 \u1082 \u1072 \u1085 \u1086 \u1074 , 10 \u1073 \u1086 \u1085 \u1091 \u1089 \u1085 \u1099 \u1093  \u1086 \u1088 \u1072 \u1082 \u1091 \u1083 \u1100 \u1085 \u1099 \u1093  \u1082 \u1072 \u1088 \u1090  \u1080  \u1072 \u1083 \u1100 \u1090 \u1077 \u1088 \u1085 \u1072 \u1090 \u1080 \u1074 \u1085 \u1099 \u1093  \u1044 \u1100 \u1103 \u1074 \u1086 \u1083 \u1072  \u1080  \u1041 \u1072 \u1096 \u1085 \u1080 . \u1055 \u1086 \u1089 \u1090 \u1072 \u1074 \u1083 \u1103 \u1077 \u1090 \u1089 \u1103  \u1074  \u1082 \u1086 \u1088 \u1086 \u1073 \u1086 \u1095 \u1082 \u1077  \u1089  \u1086 \u1073 \u1077 \u1088 \u1090 \u1082 \u1086 \u1081  \u1080  \u1089  \u1087 \u1086 \u1076 \u1087 \u1080 \u1089 \u1100 \u1102  \u1072 \u1074 \u1090 \u1086 \u1088 \u1072 \'a0Patrick Valenza.\
\
\uc0\u1042 \u1089 \u1077  \u1085 \u1072 \u1079 \u1074 \u1072 \u1085 \u1080 \u1103  \u1074  \u1101 \u1090 \u1086 \u1081  \u1082 \u1086 \u1083 \u1086 \u1076 \u1077  \u1076 \u1072 \u1085 \u1099  \u1085 \u1072  \u1080 \u1090 \u1072 \u1083 \u1100 \u1103 \u1085 \u1089 \u1082 \u1086 \u1084  \u1103 \u1079 \u1099 \u1082 \u1077 , \u1089  \u1084 \u1072 \u1089 \u1090 \u1103 \u1084 \u1080 \'a0\u1087 \u1086 \u1076  \u1085 \u1072 \u1079 \u1074 \u1072 \u1085 \u1080 \u1077 \u1084  Spade (Swords), Bastoni (Wands), Coppe (Cups), \u1080 \'a0Danari (Pentacles). \u1050 \u1072 \u1088 \u1090 \u1099  \u1044 \u1074 \u1086 \u1088 \u1072 \'a0\u1080 \u1084 \u1077 \u1102 \u1090  \u1085 \u1072 \u1079 \u1074 \u1072 \u1085 \u1080 \u1103 \'a0Re (King), Regina (Queen), Caval (Knight) \u1080  Fante (Page). \u1044 \u1074 \u1086 \u1081 \u1082 \u1072  \u1087 \u1077 \u1085 \u1090 \u1072 \u1082 \u1083 \u1077 \u1081 \'a0\u1085 \u1072 \u1089 \u1083 \u1077 \u1076 \u1091 \u1077 \u1090  \u1092 \u1086 \u1088 \u1084 \u1091  \u1082 \u1086 \u1083 \u1086 \u1076 \u1099 \'a0\u1052 \u1072 \u1088 \u1089 \u1077 \u1083 \u1103  \u1080  \u1085 \u1077 \u1089 \u1077 \u1090  \u1074  \u1089 \u1077 \u1073 \u1077  \u1080 \u1085 \u1092 \u1086 \u1088 \u1084 \u1072 \u1094 \u1080 \u1102  \u1086 \u1073  \u1080 \u1079 \u1076 \u1072 \u1090 \u1077 \u1083 \u1077 \'a0(Deviant Moon, \u1053 \u1100 \u1102 -\u1049 \u1086 \u1088 \u1082 , 2016).\
\
\uc0\u1056 \u1091 \u1073 \u1072 \u1096 \u1082 \u1072 \'a0\u1086 \u1082 \u1088 \u1072 \u1096 \u1077 \u1085 \u1072  \u1074  \u1073 \u1086 \u1088 \u1076 \u1086 \u1074 \u1099 \u1081  \u1094 \u1074 \u1077 \u1090 , \u1089  \u1074 \u1089 \u1090 \u1072 \u1074 \u1082 \u1072 \u1084 \u1080  \u1082 \u1088 \u1077 \u1084 \u1086 \u1074 \u1099 \u1093 \'a0\u1095 \u1077 \u1090 \u1074 \u1077 \u1088 \u1090 \u1077 \u1081 \'a0\u1083 \u1091 \u1085  \u1074  \u1087 \u1088 \u1077 \u1076 \u1077 \u1083 \u1072 \u1093  \u1088 \u1086 \u1084 \u1073 \u1086 \u1074 , \u1080  \u1103 \u1074 \u1083 \u1103 \u1077 \u1090 \u1089 \u1103  \u1086 \u1073 \u1088 \u1072 \u1090 \u1080 \u1084 \u1086 \u1081 . \u1051 \u1080 \u1094 \u1086  \u1082 \u1072 \u1088 \u1090 \u1099  \u1076 \u1077 \u1084 \u1086 \u1085 \u1089 \u1090 \u1088 \u1080 \u1088 \u1091 \u1077 \u1090 \'a0\'bd \u1072 \u1085 \u1090 \u1080 \u1095 \u1085 \u1091 \u1102  \u1073 \u1077 \u1083 \u1091 \u1102  \u1088 \u1072 \u1084 \u1082 \u1091 , \u1072  \u1079 \u1072 \u1090 \u1077 \u1084  \u1073 \u1086 \u1083 \u1077 \u1077  \u1090 \u1086 \u1085 \u1082 \u1091 \u1102  \u1095 \u1077 \u1088 \u1085 \u1091 \u1102  \u1088 \u1072 \u1084 \u1082 \u1091 . \u1060 \u1086 \u1085 \u1086 \u1084  \u1076 \u1083 \u1103  \u1080 \u1079 \u1086 \u1073 \u1088 \u1072 \u1078 \u1077 \u1085 \u1080 \u1081  \u1103 \u1074 \u1083 \u1103 \u1077 \u1090 \u1089 \u1103  \u1072 \u1085 \u1090 \u1080 \u1095 \u1085 \u1099 \u1081  \u1082 \u1088 \u1077 \u1084 \u1086 \u1074 \u1099 \u1081  \u1094 \u1074 \u1077 \u1090 . \u1044 \u1083 \u1103  \u1057 \u1090 \u1072 \u1088 \u1096 \u1077 \u1075 \u1086  \u1040 \u1088 \u1082 \u1072 \u1085 \u1072  \u1095 \u1080 \u1089 \u1083 \u1086  \u1087 \u1086 \u1076 \u1087 \u1080 \u1089 \u1072 \u1085 \u1086 \'a0\u1074  \u1074 \u1077 \u1088 \u1093 \u1085 \u1077 \u1081  \u1095 \u1072 \u1089 \u1090 \u1080  \u1082 \u1072 \u1088 \u1090 \u1099  \u1088 \u1080 \u1084 \u1089 \u1082 \u1080 \u1084 \u1080  \u1094 \u1080 \u1092 \u1088 \u1072 \u1084 \u1080 . \u1053 \u1072 \u1079 \u1074 \u107